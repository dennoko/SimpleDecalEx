                        _Decal4ScaleX       ("Scale X", Float) = 1
                        _Decal4ScaleY       ("Scale Y", Float) = 1
        [lilAngle]      _Decal4Angle        ("Angle", Float) = 0
        [lilEnum]       _Decal4UVMode       ("UV Mode|UV0|UV1|UV2|UV3", Int) = 0
        [lilEnum]       _Decal4BlendMode    ("Blend Mode|Normal|Add|Screen|Multiply", Int) = 0
        [lilEnum]       _Decal4Cull         ("Cull Mode|Off|Front|Back", Int) = 0
        [lilEnum]       _Decal4Mirror       ("Mirror Mode|None|Left Only|Right Only|Symmetry Copy|Symmetry Copy (Flip)|Flip on Mirror", Int) = 0

        [lilToggle]     _Decal5Enable       ("Decal 5 Enable", Int) = 0
        [NoScaleOffset] _Decal5Tex          ("Decal 5 Texture", 2D) = "white" {}
                        _Decal5Color        ("Decal 5 Color", Color) = (1,1,1,1)
                        _Decal5PosX         ("Position X", Float) = 0.5
                        _Decal5PosY         ("Position Y", Float) = 0.5
                        _Decal5ScaleX       ("Scale X", Float) = 1
                        _Decal5ScaleY       ("Scale Y", Float) = 1
        [lilAngle]      _Decal5Angle        ("Angle", Float) = 0
        [lilEnum]       _Decal5UVMode       ("UV Mode|UV0|UV1|UV2|UV3", Int) = 0
        [lilEnum]       _Decal5BlendMode    ("Blend Mode|Normal|Add|Screen|Multiply", Int) = 0
        [lilEnum]       _Decal5Cull         ("Cull Mode|Off|Front|Back", Int) = 0
        [lilEnum]       _Decal5Mirror       ("Mirror Mode|None|Left Only|Right Only|Symmetry Copy|Symmetry Copy (Flip)|Flip on Mirror", Int) = 0

        [lilToggle]     _Decal6Enable       ("Decal 6 Enable", Int) = 0
        [NoScaleOffset] _Decal6Tex          ("Decal 6 Texture", 2D) = "white" {}
                        _Decal6Color        ("Decal 6 Color", Color) = (1,1,1,1)
                        _Decal6PosX         ("Position X", Float) = 0.5
                        _Decal6PosY         ("Position Y", Float) = 0.5
                        _Decal6ScaleX       ("Scale X", Float) = 1
                        _Decal6ScaleY       ("Scale Y", Float) = 1
        [lilAngle]      _Decal6Angle        ("Angle", Float) = 0
        [lilEnum]       _Decal6UVMode       ("UV Mode|UV0|UV1|UV2|UV3", Int) = 0
        [lilEnum]       _Decal6BlendMode    ("Blend Mode|Normal|Add|Screen|Multiply", Int) = 0
        [lilEnum]       _Decal6Cull         ("Cull Mode|Off|Front|Back", Int) = 0
        [lilEnum]       _Decal6Mirror       ("Mirror Mode|None|Left Only|Right Only|Symmetry Copy|Symmetry Copy (Flip)|Flip on Mirror", Int) = 0

        [lilToggle]     _Decal7Enable       ("Decal 7 Enable", Int) = 0
        [NoScaleOffset] _Decal7Tex          ("Decal 7 Texture", 2D) = "white" {}
                        _Decal7Color        ("Decal 7 Color", Color) = (1,1,1,1)
                        _Decal7PosX         ("Position X", Float) = 0.5
                        _Decal7PosY         ("Position Y", Float) = 0.5
                        _Decal7ScaleX       ("Scale X", Float) = 1
                        _Decal7ScaleY       ("Scale Y", Float) = 1
        [lilAngle]      _Decal7Angle        ("Angle", Float) = 0
        [lilEnum]       _Decal7UVMode       ("UV Mode|UV0|UV1|UV2|UV3", Int) = 0
        [lilEnum]       _Decal7BlendMode    ("Blend Mode|Normal|Add|Screen|Multiply", Int) = 0
        [lilEnum]       _Decal7Cull         ("Cull Mode|Off|Front|Back", Int) = 0
        [lilEnum]       _Decal7Mirror       ("Mirror Mode|None|Left Only|Right Only|Symmetry Copy|Symmetry Copy (Flip)|Flip on Mirror", Int) = 0

        [lilToggle]     _Decal8Enable       ("Decal 8 Enable", Int) = 0
        [NoScaleOffset] _Decal8Tex          ("Decal 8 Texture", 2D) = "white" {}
                        _Decal8Color        ("Decal 8 Color", Color) = (1,1,1,1)
                        _Decal8PosX         ("Position X", Float) = 0.5
                        _Decal8PosY         ("Position Y", Float) = 0.5
                        _Decal8ScaleX       ("Scale X", Float) = 1
                        _Decal8ScaleY       ("Scale Y", Float) = 1
        [lilAngle]      _Decal8Angle        ("Angle", Float) = 0
        [lilEnum]       _Decal8UVMode       ("UV Mode|UV0|UV1|UV2|UV3", Int) = 0
        [lilEnum]       _Decal8BlendMode    ("Blend Mode|Normal|Add|Screen|Multiply", Int) = 0
        [lilEnum]       _Decal8Cull         ("Cull Mode|Off|Front|Back", Int) = 0
        [lilEnum]       _Decal8Mirror       ("Mirror Mode|None|Left Only|Right Only|Symmetry Copy|Symmetry Copy (Flip)|Flip on Mirror", Int) = 0

        //----------------------------------------------------------------------------------------------------------------------
        // SimpleDecalEx: MatCap（全デカール表示領域の和集合に限定して合成する単一マットキャップ）
        [lilToggle]     _SDEXMatCapEnable        ("MatCap Enable", Int) = 0
        [NoScaleOffset] _SDEXMatCapTex           ("MatCap Texture", 2D) = "black" {}
                        _SDEXMatCapColor         ("MatCap Color", Color) = (1,1,1,1)
        [lilEnum]       _SDEXMatCapBlendMode     ("Blend Mode|Normal|Add|Screen|Multiply", Int) = 1
                        _SDEXMatCapOpacity        ("Opacity", Range(0,1)) = 1
                        _SDEXMatCapMainStrength   ("Main Color Power", Range(0,1)) = 0
                        _SDEXMatCapShadowMask     ("Shadow Mask Strength", Range(0,1)) = 0.6
                        _SDEXMatCapEnableLighting ("Enable Lighting", Range(0,1)) = 0.8

        //----------------------------------------------------------------------------------------------------------------------
        // SimpleDecalEx: デカール領域のアルファ上書き（半透明マテリアルでデカール部分を不透明化＝ステッカー表現）
        [lilToggle]     _SDEXAlphaOverrideEnable    ("Decal Sticker (Opaque)", Int) = 0
                        _SDEXAlphaOverrideStrength  ("Strength", Range(0,1)) = 1
